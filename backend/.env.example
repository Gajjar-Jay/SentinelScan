# Copy this file to .env and adjust values for your environment.

# Host/port the Flask API binds to
HOST=127.0.0.1
PORT=5000

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to "false" in production
DEBUG=true

# Set to "true" only for a trusted internal-network audit deployment.
# When "false" (default), scans of private/loopback/link-local IPs are blocked
# to prevent this service being used as an SSRF / internal network probe.
ALLOW_INTERNAL_TARGETS=false

# Max ports scanned per request (keeps a single request from hogging the worker pool)
MAX_PORTS_PER_SCAN=1024

# Requests-per-minute allowed per client IP
RATE_LIMIT=10 per minute
